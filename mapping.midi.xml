<?xml version='1.0' encoding='utf-8'?>
<mapping>
    <!-- Deck 1 -->
    <control>
        <group>[Channel1]</group>
        <key>play</key>
        <status>0x90</status>
        <midino>0x3C</midino> <!-- Note 60 -->
    </control>
    <control>
        <group>[Channel1]</group>
        <key>volume</key>
        <status>0xB0</status>
        <midino>0x07</midino>
    </control>
    <control>
